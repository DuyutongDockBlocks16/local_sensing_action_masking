<mujoco model="mirobot">
  <worldbody>
    <body name="robot4:rover" pos="-1.0 -0.5 0.2">
      <joint name="robot4:centroid" type="free" pos="0 0 0" />
      <geom name="robot4:rover-body" type="box" pos="0 0 -0.1" size="0.15 0.11 0.044" mass="80"
        material="MatBody_3" />
      <geom class="collision" type="box" pos="0 0 -0.1" size="0.15 0.11 0.044"/>
      <body name="robot4:r-l-wheel" pos="-0.1 0.12 -0.15">
        <joint name="robot4:r-l-drive-hinge" type="hinge" pos="0 0 0" axis="0 1 0" damping="1.01" />
        <geom type="cylinder" size=".05" fromto="0 0 0 0 0.05 0" mass=".125" material="MatWheel"
          condim="4" />
        <site size=".01" pos="0 .05 .03" />
        <site size=".01" pos="0 .05 -.03" />
        <site size=".01" pos="0 0 .03" />
        <site size=".01" pos="0 0 -.03" />
      </body>
      <body name="robot4:r-r-wheel" pos="-0.1 -0.12 -0.15">
        <joint name="robot4:r-r-drive-hinge" type="hinge" pos="0 0 0" axis="0 1 0" damping="1.01" />
        <geom type="cylinder" size=".05" fromto="0 0 0 0 -0.05 0" mass=".125" material="MatWheel"
          condim="4" />
        <site size=".01" pos="0 -.05 .03" />
        <site size=".01" pos="0 -.05 -.03" />
        <site size=".01" pos="0 0 .03" />
        <site size=".01" pos="0 0 -.03" />
      </body>
      <body name="robot4:ghost-steer-wheel" pos="0 0 -0.1">
        <joint name="robot4:ghost-steer-hinge" type="hinge" pos="0 0 0" axis="0 0 1" limited="true"
          range="-17 17" damping="0" />
        <geom type="cylinder" size=".01 .01" axisangle="1 0 0 90" contype="2" conaffinity="2"
          mass="0.002" />
      </body>
      <body name="robot4:f-l-wheel" pos=".1 0.15 -.15">
        <geom type="capsule" size=".005" fromto="0 0 0 0 0 .08" contype="2" conaffinity="2" />
        <joint name="robot4:f-l-steer-hinge" type="hinge" pos="0 0 0" axis="0 0 1" damping="0.01"
          limited="true" range="-40 40" />
        <body name="robot4:f-l-wheel-hub">
          <geom type="cylinder" size=".01" fromto="0 -.015 0 0 0.015 0" mass=".125"
            material="MatWheel" />
          <body name="robot4:f-l-wheel-1">
            <joint name="robot4:f-l-drive-hinge-1" type="hinge" pos="0 0 0" axis="0 1 0" damping="0.01" />
            <geom type="cylinder" size=".05" fromto="0 -.015 0 0 -0.010 0" mass=".125"
              material="MatWheel" condim="4" />
            <site size=".01" pos="0 -0.0125  0.03" />
            <site size=".01" pos="0 -0.0125 -0.03" />
          </body>
          <body name="robot4:f-l-wheel-2">
            <joint name="robot4:f-l-drive-hinge-2" type="hinge" pos="0 0 0" axis="0 1 0" damping="0.01" />
            <geom type="cylinder" size=".05" fromto="0 .010 0 0 0.015 0" mass=".125"
              material="MatWheel" condim="4" />
            <site size=".01" pos="0  0.0125  0.03" />
            <site size=".01" pos="0  0.0125 -0.03" />
          </body>
        </body>
      </body>
      <body name="robot4:f-r-wheel" pos=".1 -0.15 -.15">
        <geom type="capsule" size=".005" fromto="0 0 0 0 0 .08" contype="2" conaffinity="2" />
        <joint name="robot4:f-r-steer-hinge" type="hinge" pos="0 0 0" axis="0 0 1" damping="0.01"
          limited="true" range="-40 40" />


        <body name="robot4:f-r-wheel-hub">
          <geom type="cylinder" size=".01" fromto="0 -.015 0 0 0.015 0" mass=".125"
            material="MatWheel" />
          <body name="robot4:f-r-wheel-1">
            <joint name="robot4:f-r-drive-hinge-1" type="hinge" pos="0 0 0" axis="0 1 0" damping="0.01" />
            <geom type="cylinder" size=".05" fromto="0 -.015 0 0 -0.010 0" mass=".125"
              material="MatWheel" condim="4" />
            <site size=".01" pos="0 -0.0125  0.03" />
            <site size=".01" pos="0 -0.0125 -0.03" />
          </body>
          <body name="robot4:f-r-wheel-2">
            <joint name="robot4:f-r-drive-hinge-2" type="hinge" pos="0 0 0" axis="0 1 0" damping="0.01" />
            <geom type="cylinder" size=".05" fromto="0 .010 0 0 0.015 0" mass=".125"
              material="MatWheel" condim="4" />
            <site size=".01" pos="0  0.0125  0.03" />
            <site size=".01" pos="0  0.0125 -0.03" />
          </body>
        </body>
      </body>

      <!-- ROBOT ARM -->
      <body name="robot4:base" pos="0.00 0 -0.105" childclass="WL-MiroPRO-6R200-05MM">
        <body name="robot4:base_link" pos="0 0 0">
          <inertial pos="0 0 0.0295631" quat="0.5 0.5 -0.5 0.5" mass="0.1"
            diaginertia="0.00181346 0.00122515 0.00122515" />
          <geom class="visual" type="mesh" rgba="0.478431 0.478431 0.478431 1" mesh="base_link" />
          <geom class="collision" mesh="base_link" />

          <body name="robot4:link1" pos="0 0 0.0657039">
            <inertial pos="0.0139205 0.000175676 0.0278205"
              quat="0.63697 0.301503 0.306394 0.639912"
              mass="0.100784" diaginertia="6.20698e-05 5.14973e-05 2.49373e-05" />
            <joint name="robot4:Joint1" class="Joint1" />
            <geom class="visual" type="mesh" rgba="0.792157 0.819608 0.933333 1" mesh="link1" />
            <geom class="collision" mesh="link1" />

            <!-- quat="0.500 -0.500 -0.500 -0.500" -->
            <body name="robot4:link2" pos="0.02967 -0.0219 0.0616"
              quat="0.354 -0.354 -0.612 -0.612">
              <inertial pos="-0.000285886 -0.0166553 0.0497577"
                quat="0.707123 -0.0011095 -0.00125416 0.707089"
                mass="0.132171"
                diaginertia="0.000225757 0.000214472 2.33029e-05" />
              <joint name="robot4:Joint2" class="Joint2" />
              <geom class="visual" type="mesh" rgba="1 0.6 0.247059 1" mesh="link2" />
              <geom class="collision" mesh="link2" />

              <body name="robot4:link3" pos="0.108 0 -0.0098">
                <inertial pos="0.0158955 0.0218157 0.00468223"
                  quat="0.0042885 0.613846 -0.00270477 0.78941" mass="0.0999859"
                  diaginertia="0.000128775 0.000119394 2.89671e-05" />
                <joint name="robot4:Joint3" class="Joint3" />
                <geom class="visual" type="mesh" rgba="0.792157 0.819608 0.933333 1" mesh="link3" />
                <geom class="collision" mesh="link3" />

                <!-- quat="1 0 0 0" -->
                <body name="robot4:link4" pos="0.021295 0.1075 0.0312" quat="0.707 -0.707 0 0">
                  <inertial pos="0.0397448 -3.52691e-07 8.51159e-07"
                    quat="-1.72755e-05 0.70712 1.30532e-05 0.707094" mass="0.0455777"
                    diaginertia="2.34679e-05 1.74414e-05 1.02362e-05" />
                  <joint name="robot4:Joint4" class="Joint4" />
                  <geom class="visual" type="mesh" rgba="1 0.6 0.247059 1" mesh="link4" />
                  <geom class="collision" mesh="link4" />

                  <body name="robot4:link5" pos="0.00 -0.011 0.0615" quat="0.707 -0.707 0 0">
                    <inertial pos="0 0.006295 0.00755281" quat="1 1.17491e-05 0 0" mass="0.0143828"
                      diaginertia="1.94302e-06 1.83053e-06 1.09304e-06" />
                    <joint name="robot4:Joint5" class="Joint5" />
                    <geom class="visual" type="mesh" rgba="0.792157 0.819608 0.933333 1"
                      mesh="link5" />
                    <geom class="collision" mesh="link5" solimp="0.99 0.99 0.001" solref="0.02 1"/>


                    <body name="robot4:link6" pos="0 -0.0165 0.0105" quat="0.707 -0.707 0 0" gravcomp="1">
                      <geom type="mesh" size="0.001 0.002" mass="0.0001" mesh="link6" friction="3 0.01 0.001" solimp="0.99 0.99 0.001" solref="0.02 1"/>
                      <geom class="collision" mesh="link6" />
                      <body name="robot4:vacuum_sphere" pos="0 0 -0.028" childclass="active_adhesion">

                        <site name="robot4:vacuum_contact_site" pos="0 0 0" size="0.01"/>

                        <geom type="sphere" size="0.002" rgba="0.8 0.2 0.2 1" friction="3 0.01 0.001" solimp="0.99 0.99 0.001" solref="0.02 1"/>
                        <geom type="sphere" size="0.002" rgba="0.8 0.2 0.2 1" pos="0.0027 0.0027 0" friction="3 0.01 0.001" solimp="0.99 0.99 0.001" solref="0.02 1"/>
                        <geom type="sphere" size="0.002" rgba="0.8 0.2 0.2 1" pos="0.0027 -.0027 0" friction="3 0.01 0.001" solimp="0.99 0.99 0.001" solref="0.02 1"/>
                        <geom type="sphere" size="0.002" rgba="0.8 0.2 0.2 1" pos="-.0027 0.0027 0" friction="3 0.01 0.001" solimp="0.99 0.99 0.001" solref="0.02 1"/>
                        <geom type="sphere" size="0.002" rgba="0.8 0.2 0.2 1" pos="-.0027 -.0027 0" friction="3 0.01 0.001" solimp="0.99 0.99 0.001" solref="0.02 1"/>
                        <geom type="sphere" size="0.002" rgba="0.8 0.2 0.2 1" pos="-.003 0 0" friction="3 0.01 0.001" solimp="0.99 0.99 0.001" solref="0.02 1"/>
                        <geom type="sphere" size="0.002" rgba="0.8 0.2 0.2 1" pos=".003 0 0" friction="3 0.01 0.001" solimp="0.99 0.99 0.001" solref="0.02 1"/>
                        <geom type="sphere" size="0.002" rgba="0.8 0.2 0.2 1" pos="0 -.003 0" friction="3 0.01 0.001" solimp="0.99 0.99 0.001" solref="0.02 1"/>
                        <geom type="sphere" size="0.002" rgba="0.8 0.2 0.2 1" pos="0 .003 0" friction="3 0.01 0.001" solimp="0.99 0.99 0.001" solref="0.02 1"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>


  <tendon>
    <fixed name="robot4:rear-differential">
      <joint joint="robot4:r-l-drive-hinge" coef="1" />
      <joint joint="robot4:r-r-drive-hinge" coef="1" />
    </fixed>
  </tendon>

  <actuator>
    <motor name="robot4:drive" tendon="robot4:rear-differential" ctrllimited="true" ctrlrange="-6 6"
    gear="1.5" />
    <position name="robot4:ghost-steer" joint="robot4:ghost-steer-hinge" ctrllimited="true" ctrlrange="-.9 .9"
      gear="4.0" />
    <adhesion name="robot4:adhere_winch" body="robot4:vacuum_sphere" ctrlrange="0 1" gain="5"/>
    <position class="Robot2:Joint1" name="robot4:Joint1" joint="robot4:Joint1" gear="0.2"/>
    <position class="Robot2:Joint2" name="robot4:Joint2" joint="robot4:Joint2" gear="0.2"/>
    <position class="Robot2:Joint3" name="robot4:Joint3" joint="robot4:Joint3" gear="0.2"/>
    <position class="Robot2:Joint4" name="robot4:Joint4" joint="robot4:Joint4" gear="0.2"/>
    <position class="Robot2:Joint5" name="robot4:Joint5" joint="robot4:Joint5" gear="0.2"/>
  </actuator>

  <equality>
    <joint name="robot4:f-l-steer-hinge" joint1="robot4:f-l-steer-hinge" joint2="robot4:ghost-steer-hinge"
      polycoef="0.000093610018132620019 2.0041497325730204 1.4716131190668178 -1.0929725380842041 -3.2252012765547819"
      class="acker_solver_param" />
    <joint name="robot4:f-r-steer-hinge" joint1="robot4:f-r-steer-hinge" joint2="robot4:ghost-steer-hinge"
      polycoef="-0.00017013070152971507 2.0039379507086514 -1.4684576386267671 -1.0901354124362155 3.1974185558159771"
      class="acker_solver_param" />
  
  </equality>

  <sensor>
    <touch name="robot4:vacuum_touch" site="robot4:vacuum_contact_site"/>
  </sensor>

</mujoco>